# ชื่อ Runner ที่จะแสดงใน GitHub
RUNNER_NAME=my-self-hosted-runner

# Token สำหรับ register runner (ดูได้จาก Settings > Actions > Runners > New self-hosted runner)
RUNNER_TOKEN=your_runner_token_here

# URL ของ Repository หรือ Organization
# สำหรับ Repository: https://github.com/owner/repo
# สำหรับ Organization: https://github.com/your-org
RUNNER_REPOSITORY_URL=https://github.com/your-username/your-repo

# Labels สำหรับ runner (คั่นด้วย comma)
RUNNER_LABELS=self-hosted,docker,linux
